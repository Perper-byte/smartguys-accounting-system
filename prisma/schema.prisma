generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------
// 1. SYSTEM ACCESS
// ----------------
model User {
  id            String  @id @default(uuid()) @db.VarChar(50)
  username      String  @unique @db.VarChar(100)
  password_hash String  @db.VarChar(255)
  role          Role    @default(CASHIER) 
  is_active     Boolean @default(true)

  // Relations
  journal_entries JournalEntry[]

  @@map("users")
}


enum Role {
  CASHIER
  ACCOUNTANT
  MANAGER
  IT_PERSONNEL
}

//-----------------------------------
// 2. CHART OF ACCOUNTS (Master Data)
//-----------------------------------
model AccountType {
  id             String @id @default(uuid()) @db.VarChar(50)
  name           String @db.VarChar(100) // e.g., Asset, Liability, Equity, Revenue, Expense
  normal_balance String @db.VarChar(10) // DEBIT or CREDIT

  // Relations
  accounts Account[]

  @@map("account_types")
}

model Account {
  code         String  @id @db.VarChar(50) // PK: e.g., "1010" for Cash in Bank
  name         String  @db.VarChar(150)
  tax_category String? @db.VarChar(50) // e.g., Vatable, Non-Vatable
  type_id      String  @db.VarChar(50) // FK

  // Relations
  account_type  AccountType   @relation(fields: [type_id], references: [id])
  journal_lines JournalLine[]

  @@map("accounts")
}

//--------------------------------------------
// 3. TRANSACTIONS & BOOKKEEPING (Core Engine)
//--------------------------------------------
model Payee {
  id   String  @id @default(uuid()) @db.VarChar(50)
  name String  @db.VarChar(150)
  tin  String? @db.VarChar(50)

  // Relations
  journal_entries JournalEntry[]

  @@map("payees")
}

model JournalEntry {
  id           String   @id @default(uuid()) @db.VarChar(50)
  date         DateTime @db.DateTime
  reference_no String   @db.VarChar(100) // OR No., Invoice., Voucher No.
  vat_type     String   @default("VATABLE") @db.VarChar(20) // "VATABLE", "EXEMPT", or "ZERO_RATED"
  description  String   @db.Text
  payee_id     String?  @db.VarChar(50) // FK (Nullable for non-cash transaction)
  user_id      String   @db.VarChar(50) // FK (The Cashier/Accountant who entered it)

  // Relations
  payee Payee?        @relation(fields: [payee_id], references: [id])
  user  User          @relation(fields: [user_id], references: [id])
  lines JournalLine[]

  @@index([date]) // Makes generating BIR Tax Reports and Financial Statements lightning-fast
  @@index([reference_no]) // Speeds up searching for a specific voucher or OR number
  @@index([payee_id]) // Speeds up generating the Relief Annexes (Supplier/Customer queries)
  @@map("journal_entries")
}

model JournalLine {
  id         String  @id @default(uuid()) @db.VarChar(50)
  debit      Decimal @default(0.00) @db.Decimal(15, 2)
  credit     Decimal @default(0.00) @db.Decimal(15, 2)
  entry_id   String  @db.VarChar(50) // FK
  account_id String  @db.VarChar(50) // FK

  // Relations
  entry   JournalEntry @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [account_id], references: [code])

  @@index([account_id]) // Makes generating the General Ledger Running Balance instant
  @@index([entry_id]) // Speeds up joining lines to their parent entry
  @@map("journal_lines")
}
